#!/usr/bin/env python3
"""
Validate AWS credentials and ECR repo.
Usage: pip install boto3 python-dotenv && python scripts/validate_aws.py
Loads from .env (copy .env.example to .env and fill values).
"""

import os
import sys
from pathlib import Path

# Add project root for imports
sys.path.insert(0, str(Path(__file__).resolve().parent.parent))

def load_env():
    """Load .env if python-dotenv available."""
    try:
        from dotenv import load_dotenv
        env_path = Path(__file__).resolve().parent.parent / ".env"
        load_dotenv(env_path)
    except ImportError:
        pass  # env vars from shell are fine

def validate():
    load_env()

    required = [
        "AWS_ACCESS_KEY_ID",
        "AWS_SECRET_ACCESS_KEY",
        "AWS_REGION",
        "ECR_REPOSITORY_NAME",
    ]
    missing = [k for k in required if not os.getenv(k)]
    if missing:
        print(f"Missing env vars: {missing}")
        print("Copy .env.example to .env and fill values.")
        return False

    try:
        import boto3
    except ImportError:
        print("Install: pip install boto3 python-dotenv")
        return False

    region = os.getenv("AWS_REGION")
    repo_name = os.getenv("ECR_REPOSITORY_NAME")

    # 1. Validate credentials (STS)
    print("Checking credentials (STS)...")
    try:
        sts = boto3.client(
            "sts",
            aws_access_key_id=os.getenv("AWS_ACCESS_KEY_ID"),
            aws_secret_access_key=os.getenv("AWS_SECRET_ACCESS_KEY"),
            region_name=region,
        )
        identity = sts.get_caller_identity()
        account_id = identity["Account"]
        print(f"  OK — Account: {account_id}, Arn: {identity['Arn']}")
    except Exception as e:
        print(f"  FAIL — {e}")
        return False

    # 2. Validate ECR repo exists
    print(f"Checking ECR repo '{repo_name}'...")
    try:
        ecr = boto3.client(
            "ecr",
            aws_access_key_id=os.getenv("AWS_ACCESS_KEY_ID"),
            aws_secret_access_key=os.getenv("AWS_SECRET_ACCESS_KEY"),
            region_name=region,
        )
        resp = ecr.describe_repositories(repositoryNames=[repo_name])
        repos = resp.get("repositories", [])
        if not repos:
            print(f"  FAIL — Repo '{repo_name}' not found")
            return False
        uri = repos[0]["repositoryUri"]
        print(f"  OK — URI: {uri}")
    except Exception as e:
        if "RepositoryNotFound" in str(type(e).__name__) or "RepositoryNotFound" in str(e):
            print(f"  FAIL — Repo '{repo_name}' not found")
        else:
            print(f"  FAIL — {e}")
        return False

    print("\nAll checks passed. Credentials and ECR repo are valid.")
    return True

if __name__ == "__main__":
    ok = validate()
    sys.exit(0 if ok else 1)
